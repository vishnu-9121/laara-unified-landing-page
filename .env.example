# --- DATABASE (Supabase / PostgreSQL) ---
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-ID].supabase.co:6543/postgres?pgbouncer=true"

# --- NEXTAUTH CONFIG ---
NEXTAUTH_SECRET="use-npx-auth-secret-to-generate-this"
NEXTAUTH_URL="http://localhost:3000"

# --- SOCIAL AUTH (Google) ---
# Get these from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# --- SOCIAL AUTH (LinkedIn) ---
# Get these from: https://www.linkedin.com/developers/
LINKEDIN_CLIENT_ID="your-linkedin-client-id"
LINKEDIN_CLIENT_SECRET="your-linkedin-client-secret"

# --- APP CONFIG ---
NEXT_PUBLIC_API_URL="http://localhost:3000/api"
NODE_ENV="development"
